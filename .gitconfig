[core]
	fsmonitor = true
	untrackedcache = true
	commitgraph = true
	pager = delta

[fetch]
	writeCommitGraph = true

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true  # use n and N to move between diff sections
	syntax-theme = ansi
	tabs = 4

	file-style = omit
	file-decoration-style = none
	line-numbers-left-format = "{nm:>4}▕ "
	line-numbers-right-format = "│ {np:>4}▕ "
	line-numbers-left-style = white dim
	line-numbers-right-style = white dim
	line-numbers-zero-style = white dim
	line-numbers-plus-style = green
	line-numbers-minus-style = red
	line-numbers-zero-style = white dim
	
	wrap-left-symbol = " "
	wrap-right-symbol = " "
	wrap-right-prefix-symbol = " "
	
	hunk-label = " 󰡏"
	hunk-header-line-number-style = white dim
	hunk-header-style = white
	hunk-header-file-style = white dim
	hunk-header-decoration-style = blue ol ul

[merge]
	conflictstyle = zdiff3

[init]
	defaultBranch = main

[user]
	email = abdhawisa@gmail.com
	name = abdmoh123

[includeIf "gitdir:D:/Projects/Dontyne Projects/**"]
	path = "D:/Projects/Dontyne Projects/.gitconfig"

[includeIf "gitdir:D:/D Documents/Projects/Coding/Work Projects/**"]
	path = "D:/D Documents/Projects/Coding/Work Projects/.gitconfig"

[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true

[credential "https://github.com"]
	helper = !'C:\\Program Files\\GitHub CLI\\gh.exe' auth git-credential
	helper = !/usr/bin/gh auth git-credential

[credential "https://gist.github.com"]
	helper = !'C:\\Program Files\\GitHub CLI\\gh.exe' auth git-credential
	helper = !/usr/bin/gh auth git-credential
